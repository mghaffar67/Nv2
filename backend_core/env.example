# Noor Official V3 - Production Environment Matrix
# Architecture: AWS EC2 (Ubuntu) + AWS S3 (Storage)

# --- CORE SERVER ---
PORT=8080
NODE_ENV=production
APP_URL=https://api.noorofficial.com
FRONTEND_URL=https://noorofficial.com
JWT_SECRET=YOUR_SECURE_RANDOM_LONG_STRING

# --- DATABASE (MongoDB Atlas recommended) ---
MONGO_URI=mongodb+srv://admin:password@cluster0.pkr.mongodb.net/noor_production

# --- CLOUD STORAGE (AWS S3) ---
# Create an IAM user with 'AmazonS3FullAccess' policy
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=noor-v3-production-assets

# --- EXTERNAL INTEGRATIONS ---
# Google Gemini API Key for AI Features
API_KEY=AIza...

# --- CONTACT PROTOCOLS ---
WHATSAPP_PHONE=923068665907
SUPPORT_EMAIL=help@noorofficial.com